# ─────────────────────────────────────────────────────────────────────────────
# AsterPanel — development environment configuration
# Copy to .env and adjust. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────────────────────

# --- General ---
ASTERPANEL_ENV=development
LOG_LEVEL=debug
LOG_FORMAT=json

# --- Control Plane ---
CONTROL_PLANE_HTTP_ADDR=:8080
CONTROL_PLANE_PUBLIC_URL=http://localhost:8080
WEB_PUBLIC_URL=http://localhost:3000
# Comma-separated allowed CORS origins (strict).
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=asterpanel
POSTGRES_PASSWORD=asterpanel_dev_pw
POSTGRES_DB=asterpanel
# Assembled DSN (used by control-plane and migrate).
DATABASE_URL=postgres://asterpanel:asterpanel_dev_pw@postgres:5432/asterpanel?sslmode=disable

# --- Redis (cache / sessions / rate-limit) ---
REDIS_URL=redis://redis:6379/0

# --- NATS (event bus / jobs) ---
NATS_URL=nats://nats:4222

# --- OPA ---
OPA_URL=http://opa:8181

# --- Auth / JWT ---
# 32-byte base64 secret used to sign access JWTs (HS256 in dev; prefer asymmetric in prod).
JWT_SIGNING_SECRET=CHANGE_ME_dev_only_base64_32_bytes_AAAAAAAAAAA=
ACCESS_TOKEN_TTL=10m
REFRESH_TOKEN_TTL=720h
JWT_ISSUER=asterpanel
JWT_AUDIENCE=asterpanel-web

# WebAuthn / Passkeys
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=AsterPanel
WEBAUTHN_RP_ORIGIN=http://localhost:3000

# --- Job signing (Control Plane → Agent) ---
# Ed25519 keypair (generated by `make secrets`). Paths inside the container.
JOB_SIGNING_KEY_ID=cp-dev-1
JOB_SIGNING_PRIVATE_KEY_PATH=/secrets/job-signing/ed25519.key
JOB_SIGNING_PUBLIC_KEY_PATH=/secrets/job-signing/ed25519.pub
JOB_DEFAULT_TTL=30s

# --- mTLS (Control Plane ↔ Agent) ---
MTLS_CA_CERT_PATH=/secrets/ca/ca.crt
MTLS_CA_KEY_PATH=/secrets/ca/ca.key
CONTROL_PLANE_CLIENT_CERT_PATH=/secrets/control-plane/client.crt
CONTROL_PLANE_CLIENT_KEY_PATH=/secrets/control-plane/client.key

# --- Secrets encryption at rest (envelope key for the `secrets` table) ---
# 32-byte base64 data-encryption key. In prod this is sealed by Vault/SOPS, not in .env.
SECRETS_MASTER_KEY=CHANGE_ME_dev_only_base64_32_bytes_BBBBBBBBBBB=

# --- Node Agent (per-node; set on the host, shown here for reference) ---
AGENT_NODE_ID=node-dev-1
AGENT_LISTEN_ADDR=0.0.0.0:7443
AGENT_TLS_CERT_PATH=/secrets/agent/agent.crt
AGENT_TLS_KEY_PATH=/secrets/agent/agent.key
AGENT_CA_CERT_PATH=/secrets/ca/ca.crt
# Pinned Control-Plane Ed25519 public key the agent trusts for job signatures.
AGENT_TRUSTED_JOB_PUBKEY_PATH=/secrets/job-signing/ed25519.pub
AGENT_CONTROL_PLANE_CALLBACK_URL=https://control-plane:8443
